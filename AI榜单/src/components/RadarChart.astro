---
interface Props {
  editorialScore: number;
  deploymentRating: number;
  vibeCodingRating: number;
  size?: number;
}

const { editorialScore, deploymentRating, vibeCodingRating, size = 200 } = Astro.props;

const cx = size / 2;
const cy = size / 2;
const radius = size * 0.38;

const labels = ['综合评分', '开箱即用度', 'Vibe Coding 友好度'];

// 3 axes at 120° intervals, starting from top (270°)
const angles = [-90, 30, 150].map((deg) => (deg * Math.PI) / 180);

function polarToCartesian(r: number, angleIdx: number) {
  return {
    x: cx + r * Math.cos(angles[angleIdx]),
    y: cy + r * Math.sin(angles[angleIdx]),
  };
}

// Grid levels (1-5)
const levels = [1, 2, 3, 4, 5];
const scores = [editorialScore, deploymentRating, vibeCodingRating];

// Grid polygons
function gridPolygon(level: number) {
  const r = (radius * level) / 5;
  const pts = [0, 1, 2].map((i) => polarToCartesian(r, i));
  return pts.map((p) => `${p.x},${p.y}`).join(' ');
}

// Data polygon
function dataPolygon() {
  const pts = scores.map((s, i) => polarToCartesian((radius * s) / 5, i));
  return pts.map((p) => `${p.x},${p.y}`).join(' ');
}

// Axis end points + labels
const axisEnds = [0, 1, 2].map((i) => polarToCartesian(radius, i));
const axisEndsLabel = [0, 1, 2].map((i) => {
  const p = polarToCartesian(radius + 22, i);
  return { x: p.x, y: p.y };
});
---

<svg width={size} height={size} viewBox={`0 0 ${size} ${size}`} class="radar-chart" role="img" aria-label="评分雷达图">
  <!-- Grid lines -->
  {levels.map((level) => (
    <polygon
      points={gridPolygon(level)}
      fill="none"
      stroke="#e5e7eb"
      stroke-width="1"
    />
  ))}

  <!-- Grid level labels -->
  {[1, 3, 5].map((level) => {
    const r = (radius * level) / 5;
    const p = polarToCartesian(r, 0);
    return (
      <text x={p.x + 8} y={p.y + 1} fill="#9ca3af" font-size="9" dominant-baseline="middle">
        {level}
      </text>
    );
  })}

  <!-- Axes -->
  {[0, 1, 2].map((i) => {
    const p = axisEnds[i];
    return (
      <line x1={cx} y1={cy} x2={p.x} y2={p.y} stroke="#d1d5db" stroke-width="1" />
    );
  })}

  <!-- Data polygon fill -->
  <polygon
    points={dataPolygon()}
    fill="rgba(37, 99, 235, 0.15)"
    stroke="#2563eb"
    stroke-width="2"
    stroke-linejoin="round"
  >
    <animate
      attributeName="opacity"
      from="0"
      to="1"
      dur="0.6s"
      fill="freeze"
    />
  </polygon>

  <!-- Data points -->
  {scores.map((score, i) => {
    if (score === 0) return null;
    const p = polarToCartesian((radius * score) / 5, i);
    return (
      <circle cx={p.x} cy={p.y} r="4" fill="#2563eb" stroke="white" stroke-width="2">
        <animate
          attributeName="r"
          from="0"
          to="4"
          dur="0.4s"
          begin={`${i * 0.15}s`}
          fill="freeze"
        />
      </circle>
    );
  })}

  <!-- Score values on axes -->
  {scores.map((score, i) => {
    const p = polarToCartesian((radius * score) / 5 + 14, i);
    return (
      <text
        x={p.x}
        y={p.y}
        fill="#2563eb"
        font-size="11"
        font-weight="600"
        text-anchor="middle"
        dominant-baseline="middle"
      >
        {score}/5
      </text>
    );
  })}

  <!-- Axis labels -->
  {[0, 1, 2].map((i) => (
    <text
      x={axisEndsLabel[i].x}
      y={axisEndsLabel[i].y}
      fill="#6b7280"
      font-size="11"
      text-anchor="middle"
      dominant-baseline="middle"
    >
      {labels[i]}
    </text>
  ))}
</svg>
