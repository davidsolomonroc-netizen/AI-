---
interface Props {
  score: number;
  size?: 'sm' | 'md' | 'lg';
}

const { score, size = 'md' } = Astro.props;

const sizeMap = { sm: 16, md: 20, lg: 24 };
const px = sizeMap[size];
const filledStar = 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z';
const emptyStar = 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z';
---

<span class="inline-flex items-center gap-0.5" aria-label={`${score} out of 5 stars`}>
  {
    Array.from({ length: 5 }, (_, i) => (
      <svg
        width={px}
        height={px}
        viewBox="0 0 24 24"
        class={i < score ? 'text-amber-400' : 'text-gray-200'}
        fill="currentColor"
      >
        <path d={filledStar} />
      </svg>
    ))
  }
</span>
