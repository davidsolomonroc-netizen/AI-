---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到 - AI 榜单">
  <div class="max-w-6xl mx-auto px-4 py-24 text-center">
    <p class="text-8xl font-extrabold text-gray-200 mb-4">404</p>
    <h1 class="text-2xl font-bold text-gray-900 mb-3">页面未找到</h1>
    <p class="text-gray-500 mb-8">抱歉，您访问的页面不存在</p>
    <a
      href="/"
      class="inline-flex px-6 py-3 bg-brand-600 text-white rounded-lg hover:bg-brand-700 transition-colors font-medium"
    >
      返回首页
    </a>
  </div>
</BaseLayout>
