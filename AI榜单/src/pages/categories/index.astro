---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const categoryLabels: Record<string, string> = {
  'agent-framework': 'Agent 框架',
  'dev-tools': '开发工具',
  'multimodal': '多模态',
  'code-generation': '代码生成',
  'workflow-automation': '工作流自动化',
  'data-analysis': '数据分析',
  'other': '其他',
};

const categoryDescriptions: Record<string, string> = {
  'agent-framework': '多 Agent 协作、任务编排、自主决策框架',
  'dev-tools': '提升开发效率的工具链和平台',
  'multimodal': '图像、视频、音频等多模态 AI 工具',
  'code-generation': '代码自动生成和辅助编程工具',
  'workflow-automation': '业务流程自动化和 RPA 工具',
  'data-analysis': '数据分析、可视化和 BI 工具',
  'other': '其他未分类的 AI 项目',
};

const groups: Record<string, typeof allProjects> = {};
for (const p of allProjects) {
  const cat = p.data.category;
  if (!groups[cat]) groups[cat] = [];
  groups[cat].push(p);
}
---

<BaseLayout title="分类浏览 - AI 榜单" description="按类别浏览 AI 开源项目">
  <div class="max-w-6xl mx-auto px-4 py-10">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">分类浏览</h1>
    <p class="text-gray-500 text-sm mb-8">按类别浏览 AI 开源项目</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {Object.entries(categoryLabels).map(([slug, label]) => {
        const projects = groups[slug] || [];
        if (projects.length === 0) return null;
        return (
          <a
            key={slug}
            href={`/categories/${slug}`}
            class="rounded-xl border border-gray-200 bg-white p-6 hover:shadow-md hover:border-gray-300 transition-all duration-200"
          >
            <h2 class="text-lg font-semibold text-gray-900 mb-1">{label}</h2>
            <p class="text-sm text-gray-500 mb-3">{categoryDescriptions[slug]}</p>
            <span class="text-sm text-brand-600 font-medium">{projects.length} 个项目 →</span>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
