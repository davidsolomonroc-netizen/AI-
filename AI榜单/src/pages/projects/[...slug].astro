---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ScoreStars from '@/components/ScoreStars.astro';
import NewsletterForm from '@/components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;

const categoryLabels: Record<string, string> = {
  'agent-framework': 'Agent 框架',
  'dev-tools': '开发工具',
  'multimodal': '多模态',
  'code-generation': '代码生成',
  'workflow-automation': '工作流自动化',
  'data-analysis': '数据分析',
  'other': '其他',
};

const categoryColors: Record<string, string> = {
  'agent-framework': 'bg-purple-100 text-purple-700',
  'dev-tools': 'bg-blue-100 text-blue-700',
  'multimodal': 'bg-green-100 text-green-700',
  'code-generation': 'bg-orange-100 text-orange-700',
  'workflow-automation': 'bg-pink-100 text-pink-700',
  'data-analysis': 'bg-teal-100 text-teal-700',
  'other': 'bg-gray-100 text-gray-700',
};
---

<BaseLayout title={`${data.title} - AI 榜单`} description={data.commercialSummary}>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-brand-600">首页</a>
      <span class="mx-2">›</span>
      <a href={`/categories/${data.category}`} class="hover:text-brand-600">
        {categoryLabels[data.category] || data.category}
      </a>
      <span class="mx-2">›</span>
      <span class="text-gray-800">{data.title}</span>
    </nav>

    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3 flex-wrap">
        <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${categoryColors[data.category] || categoryColors['other']}`}>
          {categoryLabels[data.category] || data.category}
        </span>
        <span class="text-sm text-gray-500">★ {data.githubStars.toLocaleString()}</span>
        <span class="text-sm text-gray-400">{data.publishDate.toLocaleDateString('zh-CN')}</span>
      </div>
      <h1 class="text-3xl font-bold text-gray-900 mb-2">{data.title}</h1>
      <p class="text-gray-600">{data.description}</p>
    </div>

    <!-- Score Card -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
      <div class="bg-white rounded-xl border border-gray-200 p-5 text-center">
        <p class="text-sm text-gray-500 mb-2">综合评分</p>
        <ScoreStars score={data.editorialScore} size="lg" />
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-5 text-center">
        <p class="text-sm text-gray-500 mb-2">开箱即用度</p>
        <ScoreStars score={data.deploymentRating} size="lg" />
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-5 text-center">
        <p class="text-sm text-gray-500 mb-2">Vibe Coding 友好度</p>
        <ScoreStars score={data.vibeCodingRating} size="lg" />
      </div>
    </div>

    <!-- GitHub Link -->
    <div class="mb-8">
      <a
        href={data.githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 bg-gray-900 text-white text-sm rounded-lg hover:bg-gray-800 transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        在 GitHub 上查看
      </a>
    </div>

    <!-- Tags -->
    {data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {data.tags.map((tag) => (
          <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs">{tag}</span>
        ))}
      </div>
    )}

    <!-- Commercial Summary -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">商业价值摘要</h2>
      <div class="bg-blue-50 border border-blue-100 rounded-xl p-5 text-gray-700 leading-relaxed">
        {data.commercialSummary}
      </div>
    </section>

    <!-- Vibe Coding Prompt -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">Vibe Coding 实战提示</h2>
      <p class="text-sm text-gray-500 mb-3">复制以下 Prompt 到 Claude Code 或 Cursor 中使用：</p>
      <div class="relative group">
        <pre class="bg-gray-900 text-gray-100 rounded-xl p-5 text-sm leading-relaxed overflow-x-auto whitespace-pre-wrap">{(data.vibeCodingPrompt)}</pre>
        <button
          class="copy-btn absolute top-3 right-3 px-3 py-1.5 bg-white/10 text-white text-xs rounded-lg hover:bg-white/20 transition-colors opacity-0 group-hover:opacity-100"
          data-copy={data.vibeCodingPrompt}
        >复制</button>
      </div>
    </section>

    <!-- Pitfall Guide -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">避坑指南</h2>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-5">
        <div class="prose prose-sm max-w-none text-gray-700 whitespace-pre-wrap leading-relaxed">
          {data.pitfallGuide}
        </div>
      </div>
    </section>

    <!-- Affiliate Link -->
    {data.affiliateLink && (
      <section class="mb-8">
        <a
          href={data.affiliateLink}
          target="_blank"
          rel="noopener noreferrer"
          class="block text-center bg-brand-600 text-white rounded-xl p-4 hover:bg-brand-700 transition-colors font-medium"
        >
          获取专属优惠 →
        </a>
      </section>
    )}

    <!-- Full Body -->
    <div class="prose prose-gray max-w-none mb-12">
      <slot />
    </div>

    <!-- Newsletter -->
    <NewsletterForm />
  </div>

  <style>
    .prose h2 {
      font-size: 1.25rem;
      font-weight: 600;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      color: #111827;
    }
    .prose h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
      color: #1f2937;
    }
    .prose p {
      margin-bottom: 1rem;
      line-height: 1.75;
      color: #374151;
    }
    .prose ul {
      list-style: disc;
      padding-left: 1.5rem;
      margin-bottom: 1rem;
    }
    .prose li {
      margin-bottom: 0.25rem;
      color: #374151;
    }
  </style>

  <script>
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const text = btn.getAttribute('data-copy');
        await navigator.clipboard.writeText(text);
        btn.textContent = '已复制!';
        setTimeout(() => { btn.textContent = '复制'; }, 2000);
      });
    });
  </script>
</BaseLayout>
