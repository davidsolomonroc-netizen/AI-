---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ScoreStars from '@/components/ScoreStars.astro';
import RadarChart from '@/components/RadarChart.astro';
import NewsletterForm from '@/components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;

const categoryLabels: Record<string, string> = {
  'agent-framework': 'Agent 框架',
  'dev-tools': '开发工具',
  'multimodal': '多模态',
  'code-generation': '代码生成',
  'workflow-automation': '工作流自动化',
  'data-analysis': '数据分析',
  'other': '其他',
};

const categoryColors: Record<string, string> = {
  'agent-framework': 'bg-purple-100 text-purple-700',
  'dev-tools': 'bg-blue-100 text-blue-700',
  'multimodal': 'bg-green-100 text-green-700',
  'code-generation': 'bg-orange-100 text-orange-700',
  'workflow-automation': 'bg-pink-100 text-pink-700',
  'data-analysis': 'bg-teal-100 text-teal-700',
  'other': 'bg-gray-100 text-gray-700',
};

const audienceColors: Record<string, string> = {
  '独立开发者': 'bg-indigo-100 text-indigo-700',
  '创业者': 'bg-rose-100 text-rose-700',
  '产品经理': 'bg-amber-100 text-amber-700',
  '企业团队': 'bg-blue-100 text-blue-700',
  'AI 研究者': 'bg-violet-100 text-violet-700',
  '内容创作者': 'bg-pink-100 text-pink-700',
  '数据分析师': 'bg-teal-100 text-teal-700',
  '技术负责人': 'bg-cyan-100 text-cyan-700',
};

const totalScore = ((data.editorialScore + data.deploymentRating + data.vibeCodingRating) / 3).toFixed(1);
---

<BaseLayout title={`${data.title} - AI 榜单`} description={data.commercialSummary}>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-brand-600 transition-colors">首页</a>
      <span class="mx-2">›</span>
      <a href={`/categories/${data.category}`} class="hover:text-brand-600 transition-colors">
        {categoryLabels[data.category] || data.category}
      </a>
      <span class="mx-2">›</span>
      <span class="text-gray-800 font-medium">{data.title}</span>
    </nav>

    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3 flex-wrap">
        <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${categoryColors[data.category] || categoryColors['other']}`}>
          {categoryLabels[data.category] || data.category}
        </span>
        <span class="text-sm text-gray-500 flex items-center gap-1">
          <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {data.githubStars.toLocaleString()}
        </span>
        <span class="text-sm text-gray-400">·</span>
        <span class="text-sm text-gray-500">{data.publishDate.toLocaleDateString('zh-CN')}</span>
      </div>
      <h1 class="text-3xl font-bold text-gray-900 mb-2">{data.title}</h1>
      <p class="text-gray-600 text-lg">{data.description}</p>
    </div>

    <!-- Radar Chart + Scores + Quick Stats -->
    <div class="bg-white rounded-xl border border-gray-200 p-6 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
        <!-- Radar Chart -->
        <div class="flex justify-center">
          <RadarChart
            editorialScore={data.editorialScore}
            deploymentRating={data.deploymentRating}
            vibeCodingRating={data.vibeCodingRating}
          />
        </div>

        <!-- Score Details -->
        <div class="space-y-4">
          <div class="text-center md:text-left">
            <span class="text-3xl font-bold text-brand-600">{totalScore}</span>
            <span class="text-gray-500 text-sm ml-1">/ 5 综合评分</span>
          </div>

          <div class="bg-gray-50 rounded-lg p-4">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm text-gray-600 font-medium">综合评分</span>
              <span class="text-sm text-gray-400">创新性 · 活跃度 · 代码质量</span>
            </div>
            <ScoreStars score={data.editorialScore} size="lg" />
          </div>

          <div class="bg-gray-50 rounded-lg p-4">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm text-gray-600 font-medium">开箱即用度</span>
              <span class="text-sm text-gray-400">10 分钟内跑通？</span>
            </div>
            <ScoreStars score={data.deploymentRating} size="lg" />
          </div>

          <div class="bg-gray-50 rounded-lg p-4">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm text-gray-600 font-medium">Vibe Coding 友好度</span>
              <span class="text-sm text-gray-400">适合 Claude Code/Cursor？</span>
            </div>
            <ScoreStars score={data.vibeCodingRating} size="lg" />
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Info Bar -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
      <div class="bg-gray-50 rounded-lg p-3 text-center">
        <p class="text-xs text-gray-500 mb-1">GitHub 星数</p>
        <p class="text-lg font-bold text-gray-800">{data.githubStars.toLocaleString()}</p>
      </div>
      <div class="bg-gray-50 rounded-lg p-3 text-center">
        <p class="text-xs text-gray-500 mb-1">主要语言</p>
        <p class="text-lg font-bold text-gray-800">{data.tags[0] || 'N/A'}</p>
      </div>
      <div class="bg-gray-50 rounded-lg p-3 text-center">
        <p class="text-xs text-gray-500 mb-1">分类</p>
        <p class="text-lg font-bold text-gray-800">{categoryLabels[data.category] || data.category}</p>
      </div>
      <div class="bg-gray-50 rounded-lg p-3 text-center">
        <p class="text-xs text-gray-500 mb-1">收录日期</p>
        <p class="text-lg font-bold text-gray-800">{data.publishDate.toLocaleDateString('zh-CN')}</p>
      </div>
    </div>

    <!-- Target Audience -->
    {data.targetAudience && data.targetAudience.length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          适合人群
        </h2>
        <div class="flex flex-wrap gap-2">
          {data.targetAudience.map((audience) => (
            <span class={`px-3 py-1.5 rounded-lg text-sm font-medium ${audienceColors[audience] || 'bg-gray-100 text-gray-700'}`}>
              {audience}
            </span>
          ))}
        </div>
      </section>
    )}

    <!-- Use Cases -->
    {data.useCases && data.useCases.length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
          </svg>
          适用场景
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {data.useCases.map((useCase) => (
            <div class="flex items-center gap-2 px-4 py-2.5 bg-gray-50 rounded-lg text-sm text-gray-700">
              <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              {useCase}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- GitHub Link -->
    <div class="mb-8 flex flex-wrap gap-3">
      <a
        href={data.githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-gray-900 text-white text-sm rounded-lg hover:bg-gray-800 transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        在 GitHub 上查看
      </a>
    </div>

    <!-- Tags -->
    {data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {data.tags.map((tag) => (
          <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs">#{tag}</span>
        ))}
      </div>
    )}

    <!-- Commercial Summary -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3 flex items-center gap-2">
        <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        商业价值摘要
      </h2>
      <div class="bg-gradient-to-r from-blue-50 to-blue-50/30 border border-blue-100 rounded-xl p-5 text-gray-700 leading-relaxed">
        {data.commercialSummary}
      </div>
    </section>

    <!-- Vibe Coding Prompt -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3 flex items-center gap-2">
        <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
        </svg>
        Vibe Coding 实战提示
      </h2>
      <p class="text-sm text-gray-500 mb-3">复制以下 Prompt 到 Claude Code 或 Cursor 中使用：</p>
      <div class="relative group">
        <pre class="bg-gray-900 text-gray-100 rounded-xl p-5 text-sm leading-relaxed overflow-x-auto whitespace-pre-wrap">{(data.vibeCodingPrompt)}</pre>
        <button
          class="copy-btn absolute top-3 right-3 px-3 py-1.5 bg-white/20 text-white text-xs rounded-lg hover:bg-white/30 transition-colors"
          data-copy={data.vibeCodingPrompt}
        >复制</button>
      </div>
    </section>

    <!-- Pitfall Guide -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3 flex items-center gap-2">
        <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
        </svg>
        避坑指南
      </h2>
      <div class="bg-gradient-to-r from-amber-50 to-amber-50/30 border border-amber-200 rounded-xl p-5">
        <ul class="space-y-2 text-sm text-gray-700">
          {data.pitfallGuide.split('\n').filter(Boolean).map((item) => (
            <li class="flex items-start gap-2">
              <span class="text-amber-500 mt-0.5 flex-shrink-0">⚠</span>
              <span>{item.replace(/^\d+[\.\、]\s*/, '')}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Affiliate Link -->
    {data.affiliateLink && (
      <section class="mb-8">
        <a
          href={data.affiliateLink}
          target="_blank"
          rel="noopener noreferrer"
          class="block text-center bg-gradient-to-r from-brand-600 to-brand-700 text-white rounded-xl p-4 hover:from-brand-700 hover:to-brand-800 transition-all duration-200 font-medium shadow-sm"
        >
          <span class="flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/>
            </svg>
            获取专属优惠 →
          </span>
        </a>
      </section>
    )}

    <!-- Full Body -->
    <div class="prose prose-gray max-w-none mb-12">
      <slot />
    </div>

    <!-- Newsletter -->
    <div class="bg-gradient-to-r from-brand-50 to-blue-50 rounded-xl p-6 mb-8">
      <NewsletterForm />
    </div>
  </div>

  <style>
    .prose h2 {
      font-size: 1.25rem;
      font-weight: 600;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      color: #111827;
    }
    .prose h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
      color: #1f2937;
    }
    .prose p {
      margin-bottom: 1rem;
      line-height: 1.75;
      color: #374151;
    }
    .prose ul {
      list-style: disc;
      padding-left: 1.5rem;
      margin-bottom: 1rem;
    }
    .prose li {
      margin-bottom: 0.25rem;
      color: #374151;
    }

    @keyframes score-pop {
      from { opacity: 0; transform: scale(0.8); }
      to { opacity: 1; transform: scale(1); }
    }
    .radar-chart-wrapper {
      animation: score-pop 0.5s ease-out;
    }
  </style>

  <script>
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const text = btn.getAttribute('data-copy');
        await navigator.clipboard.writeText(text);
        btn.textContent = '✓ 已复制!';
        btn.classList.add('bg-green-500/30', 'text-green-300');
        setTimeout(() => {
          btn.textContent = '复制';
          btn.classList.remove('bg-green-500/30', 'text-green-300');
        }, 2000);
      });
    });
  </script>
</BaseLayout>
